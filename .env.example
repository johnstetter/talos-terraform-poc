# Proxmox Authentication (API Token - Recommended)
# Create API token in Proxmox: Datacenter → Permissions → API Tokens
# Format: username@realm!tokenid=secret (e.g., terraform@pve!mytoken=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
PROXMOX_VE_API_TOKEN=terraform@pve!terraform-token=your-api-token-secret-here

# Proxmox Connection Settings
PROXMOX_VE_ENDPOINT=https://your-proxmox.example.com:8006/
PROXMOX_VE_SSH_USERNAME=root

# Terraform Variables (these override defaults in variables.tf)
TF_VAR_proxmox_endpoint=https://your-proxmox.example.com:8006/
TF_VAR_proxmox_api_token=terraform@pve!terraform-token=your-api-token-secret-here
TF_VAR_proxmox_ssh_username=root
TF_VAR_proxmox_insecure=true

# Talos Cluster Configuration
TF_VAR_talos_cluster_name=talos-homelab
TF_VAR_talos_version=1.9.5
TF_VAR_kubernetes_version=1.31.0

# Network Configuration
TF_VAR_cluster_vip=10.0.0.100
TF_VAR_cluster_domain=cluster.local
TF_VAR_service_subnet=10.96.0.0/12
TF_VAR_pod_subnet=10.244.0.0/16

# VM Configuration
TF_VAR_vm_cpu_cores=4
TF_VAR_vm_memory_mb=8192
TF_VAR_vm_disk_size=50G

# Node Configuration (JSON format for complex variables)
# TF_VAR_control_nodes='{"control-0":"pve1","control-1":"pve1","control-2":"pve1"}'
# TF_VAR_worker_nodes='{"worker-0":"pve1","worker-1":"pve1","worker-2":"pve1"}'

# Timezone (for local development)
TZ=America/Chicago