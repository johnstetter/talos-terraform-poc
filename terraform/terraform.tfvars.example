# Proxmox Configuration
proxmox_endpoint     = "https://your-proxmox.example.com:8006/"
proxmox_api_token    = "terraform@pve!terraform-token=your-api-token-secret-here"
proxmox_ssh_username = "root"
proxmox_insecure     = true

# Talos Cluster Configuration
talos_cluster_name = "talos-homelab"
talos_version      = "1.9.5"
kubernetes_version = "1.31.0"

# Network Configuration
cluster_vip    = "10.0.0.100"
cluster_domain = "cluster.local"
service_subnet = "10.96.0.0/12"
pod_subnet     = "10.244.0.0/16"

# VM Configuration
vm_cpu_cores  = 4
vm_memory_mb  = 8192
vm_disk_size  = "50G"

# Node Configuration
control_nodes = {
  "control-0" = "pve1"
  "control-1" = "pve1"
  "control-2" = "pve1"
}

worker_nodes = {
  "worker-0" = "pve1"
  "worker-1" = "pve1"
  "worker-2" = "pve1"
}