# Production Environment Configuration
# Copy to terraform.tfvars and customize

# Proxmox Configuration
proxmox_endpoint     = "https://192.168.1.5:8006/"
proxmox_api_token    = "terraform@pve!terraform=your-api-token-secret-here"
proxmox_ssh_username = "root"
proxmox_insecure     = true

# Talos Cluster Configuration (Production)
talos_cluster_name = "talos-prod"
talos_version      = "1.9.5"
kubernetes_version = "1.31.0"

# Network Configuration (Production)
cluster_vip    = "192.168.1.180"    # Prod cluster VIP
cluster_domain = "cluster.local"
service_subnet = "10.96.0.0/12"
pod_subnet     = "10.244.0.0/16"

# VM Configuration (Full resources for Prod)
vm_cpu_cores  = 4                   # Full CPU allocation
vm_memory_mb  = 8192                # Full RAM allocation
vm_disk_size  = "50G"               # Full disk allocation

# Node Configuration (Prod: 2 control + 3 workers)
control_nodes = {
  "prod-control-0" = "core"
  "prod-control-1" = "core"
}

worker_nodes = {
  "prod-worker-0" = "core"
  "prod-worker-1" = "core"
  "prod-worker-2" = "core"
}